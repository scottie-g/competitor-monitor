# changedetection.io — base URL of your instance
# Self-hosted: http://localhost:5000
# Cloud: https://lemonade.changedetection.io/your-instance-path
CD_BASE_URL=https://app.changedetection.io

# changedetection.io API key — Settings → API in the web UI
CD_API_KEY=your_changedetection_api_key

# Anthropic API key — console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google Sheet ID — the long string in the sheet's URL
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
SHEET_ID=your_google_sheet_id

# How far back to look for changes (hours). Default 25 survives a missed daily run.
LOOKBACK_HOURS=25

# Slack Incoming Webhook URL — optional, omit to disable notifications
SLACK_WEBHOOK_URL=
